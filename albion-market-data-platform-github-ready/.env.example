ALBION_SERVER=west
APP_ENV=development
# auto | always | never
LOG_COLOR=auto
COLLECTOR_DATA_DIR=./data
COLLECTOR_CATALOG_DIR=./catalog
COLLECTOR_LISTEN=127.0.0.1:8787
LOCAL_DATABASE_PATH=./data/database/market-state.json
LOCAL_API_URL=http://127.0.0.1:8787/api/v1

# Precio actual hacia albion-market-api.
UPSTREAM_ENABLED=true
# Si se omite, hereda el valor de UPSTREAM_ENABLED.
UPSTREAM_HISTORY_ENABLED=true
UPSTREAM_BASE_URL=http://127.0.0.1:8080
UPSTREAM_TOKEN=CHANGE_ME_STRONG_RANDOM_TOKEN

# Capacidad persistente y batches de precios actuales.
UPSTREAM_BATCH_SIZE=500
UPSTREAM_FLUSH_INTERVAL=250ms
UPSTREAM_QUEUE_SIZE=5000

# Capacidad persistente y batches de historial.
UPSTREAM_HISTORY_BATCH_SIZE=100
UPSTREAM_HISTORY_MAX_BATCH_BUCKETS=100000
UPSTREAM_HISTORY_FLUSH_INTERVAL=500ms
UPSTREAM_HISTORY_QUEUE_SIZE=1000

# Outbox persistente compartida por ambos forwarders.
UPSTREAM_OUTBOX_PATH=./data/outbox/state.json
# Intentos por ciclo inmediato.
UPSTREAM_RETRY_COUNT=3
UPSTREAM_RETRY_DELAY=500ms
# Intentos acumulados persistentes antes de mover el batch a dead-letter.
UPSTREAM_MAX_DELIVERY_ATTEMPTS=12
UPSTREAM_MAX_RETRY_DELAY=5m

# Transporte compartido por ambos forwarders.
UPSTREAM_TIMEOUT=5s
UPSTREAM_GZIP=false
