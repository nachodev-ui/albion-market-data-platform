# Perfil local seguro para reenviar Albion Data Client hacia la API pública.
ALBION_SERVER=west
APP_ENV=production
LOAD_DOTENV=true
LOG_COLOR=never
LOG_FORMAT=json

# El receiver continúa expuesto solo en loopback.
COLLECTOR_DATA_DIR=./data
COLLECTOR_CATALOG_DIR=./catalog
COLLECTOR_LISTEN=127.0.0.1:8787
COLLECTOR_ALLOW_REMOTE=false
COLLECTOR_MAX_HEADER_BYTES=65536
LOCAL_API_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOCAL_DATABASE_PATH=./data/database/market-state.json
LOCAL_API_URL=http://127.0.0.1:8787/api/v1

# Durabilidad y retención local.
STORAGE_MAX_BYTES=10737418240
STORAGE_RAW_RETENTION_DAYS=30
STORAGE_NORMALIZED_RETENTION_DAYS=365
STORAGE_BACKUP_DIR=./backups
STORAGE_BACKUP_RETENTION_DAYS=30
STORAGE_MINIMUM_BACKUPS=3

# Forwarding público a Render. UPSTREAM_BASE_URL es la raíz, sin /api/v1.
UPSTREAM_ENABLED=true
UPSTREAM_HISTORY_ENABLED=true
UPSTREAM_BASE_URL=https://albion-market-api.onrender.com
UPSTREAM_TOKEN=
UPSTREAM_TOKEN_FILE=./secrets/upstream-current.token
UPSTREAM_MIN_TOKEN_LENGTH=32
UPSTREAM_REQUIRE_HTTPS=true

# Batches de precios actuales.
UPSTREAM_BATCH_SIZE=500
UPSTREAM_FLUSH_INTERVAL=250ms
UPSTREAM_QUEUE_SIZE=5000

# Batches de historial.
UPSTREAM_HISTORY_BATCH_SIZE=100
UPSTREAM_HISTORY_MAX_BATCH_BUCKETS=100000
UPSTREAM_HISTORY_FLUSH_INTERVAL=500ms
UPSTREAM_HISTORY_QUEUE_SIZE=1000

# Outbox persistente y reintentos tolerantes a una API remota.
UPSTREAM_OUTBOX_PATH=./data/outbox/state.json
UPSTREAM_RETRY_COUNT=5
UPSTREAM_RETRY_DELAY=1s
UPSTREAM_MAX_DELIVERY_ATTEMPTS=12
UPSTREAM_MAX_RETRY_DELAY=5m
UPSTREAM_TIMEOUT=30s
UPSTREAM_GZIP=false
